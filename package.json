{
  "name": "opencode-claude-code-plugin",
  "version": "1.0.0",
  "description": "Thin wrapper around ai-sdk-provider-claude-code for OpenCode compatibility",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "ai-sdk-provider-claude-code": "^3.4.4"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "opencode",
    "claude",
    "claude-code",
    "ai-sdk",
    "provider"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/emilieneloy/opencode-claude-code-plugin"
  }
}
